{
  "name": "@ziggurat-cache/memcache",
  "version": "0.1.2",
  "description": "Memcached adapter for @ziggurat-cache/core multi-layer cache",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/camcima/ziggurat.git",
    "directory": "packages/memcache"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "keywords": [
    "cache",
    "memcache",
    "memcached",
    "layered-cache",
    "cache-adapter"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:functional": "vitest run --config vitest.functional.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@ziggurat-cache/core": "workspace:*"
  },
  "peerDependencies": {
    "memjs": "^1.3.0"
  },
  "devDependencies": {
    "memjs": "^1.3.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
