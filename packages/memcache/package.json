{
  "name": "@ziggurat/memcache",
  "version": "0.1.0",
  "description": "Memcached adapter for @ziggurat/core multi-layer cache",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/camcima/ziggurat.git",
    "directory": "packages/memcache"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "keywords": [
    "cache",
    "memcache",
    "memcached",
    "layered-cache",
    "cache-adapter"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:functional": "vitest run --config vitest.functional.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@ziggurat/core": "workspace:*"
  },
  "peerDependencies": {
    "memjs": "^1.3.0"
  },
  "devDependencies": {
    "memjs": "^1.3.0",
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
