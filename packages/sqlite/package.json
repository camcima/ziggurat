{
  "name": "@ziggurat-cache/sqlite",
  "version": "0.1.1",
  "description": "SQLite adapter for @ziggurat-cache/core multi-layer cache",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/camcima/ziggurat.git",
    "directory": "packages/sqlite"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "keywords": [
    "cache",
    "sqlite",
    "embedded-cache",
    "persistent-cache",
    "layered-cache",
    "cache-adapter"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:functional": "vitest run --config vitest.functional.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@ziggurat-cache/core": "workspace:*"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "better-sqlite3": "^12.8.0",
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^6.0.2",
    "tsup": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
